local Section = CoolTab:CreateSection("Use at your own risk.")

local Button = CoolTab:CreateButton({
   Name = "Flag ESP",
   Callback = function()
   local Button = CoolTab:CreateButton({
   Name = "Flag ESP",
   Callback = function()
    local Players = game:GetService("Players")
local lp = Players.LocalPlayer

_G.ESP = not _G.ESP

for _, p in pairs(Players:GetPlayers()) do
    if p ~= lp then
        local function apply(char)
            if not _G.ESP then return end

            local head = char:FindFirstChild("Head")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not (head and hum) then return end

            -- remove old
            if char:FindFirstChild("ESP_H") then
                char.ESP_H:Destroy()
            end
            if head:FindFirstChild("ESP_GUI") then
                head.ESP_GUI:Destroy()
            end

            -- highlight
            local h = Instance.new("Highlight")
            h.Name = "ESP_H"
            h.FillColor = Color3.new(1,0,0)
            h.OutlineColor = Color3.new(1,1,1)
            h.FillTransparency = 0.5
            h.Parent = char

            -- health bar
            local gui = Instance.new("BillboardGui")
            gui.Name = "ESP_GUI"
            gui.Size = UDim2.new(0, 100, 0, 10)
            gui.StudsOffset = Vector3.new(0, 2.5, 0)
            gui.AlwaysOnTop = true
            gui.Parent = head

            local bg = Instance.new("Frame")
            bg.Size = UDim2.new(1,0,1,0)
            bg.BackgroundColor3 = Color3.new(0,0,0)
            bg.BorderSizePixel = 0
            bg.Parent = gui

            local bar = Instance.new("Frame")
            bar.BorderSizePixel = 0
            bar.Parent = bg

            local function update()
                local hp = hum.Health / hum.MaxHealth
                bar.Size = UDim2.new(hp,0,1,0)

                if hp > 0.5 then
                    bar.BackgroundColor3 = Color3.new(0,1,0)
                elseif hp > 0.25 then
                    bar.BackgroundColor3 = Color3.new(1,1,0)
                else
                    bar.BackgroundColor3 = Color3.new(1,0,0)
                end
            end

            update()
            hum.HealthChanged:Connect(update)
        end

        if _G.ESP then
            if p.Character then apply(p.Character) end
            p.CharacterAdded:Connect(apply)
        else
            if p.Character then
                if p.Character:FindFirstChild("ESP_H") then
                    p.Character.ESP_H:Destroy()
                end
                local head = p.Character:FindFirstChild("Head")
                if head and head:FindFirstChild("ESP_GUI") then
                    head.ESP_GUI:Destroy()
                end
            end
        end
    end
end
   end,
})
