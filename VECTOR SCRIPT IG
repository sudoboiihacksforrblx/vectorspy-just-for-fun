local CoolTab = Window:CreateTab("cool stuff", 4483362458) -- Title, Image
local Section = CoolTab:CreateSection("Client")

local CoolButton = CoolTab:CreateButton({
   Name = "Highlight ESP",
   Callback = function()
   local Players = game:GetService("Players")
local lp = Players.LocalPlayer

_G.ESP = not _G.ESP

-- store connections so we can clean them
_G.ESPCons = _G.ESPCons or {}

local function applyESP(p)
    if p == lp then return end

    local function add(char)
        if not _G.ESP then return end
        if char:FindFirstChild("ESP") then return end

        local h = Instance.new("Highlight")
        h.Name = "ESP"
        h.FillColor = Color3.new(1, 0, 0)
        h.OutlineColor = Color3.new(1, 1, 1)
        h.FillTransparency = 0.5
        h.Parent = char
    end

    if p.Character then
        add(p.Character)
    end

    -- respawn support
    _G.ESPCons[p] = p.CharacterAdded:Connect(add)
end

if _G.ESP then
    -- apply to all current players
    for _, p in pairs(Players:GetPlayers()) do
        applyESP(p)
    end

    -- new players support
    _G.PlayerAddedCon = Players.PlayerAdded:Connect(applyESP)
else
    -- remove all ESP
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character then
            local h = p.Character:FindFirstChild("ESP")
            if h then h:Destroy() end
        end
    end

    -- disconnect connections
    for _, con in pairs(_G.ESPCons) do
        con:Disconnect()
    end
    _G.ESPCons = {}

    if _G.PlayerAddedCon then
        _G.PlayerAddedCon:Disconnect()
        _G.PlayerAddedCon = nil
    end
end
   end,
})

